# LLM Provider 選擇：ollama | openai | gemini | anthropic
LLM_PROVIDER=ollama

# Ollama（本地端，OpenAI 相容）
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini（透過 OpenAI 相容端點）
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Context 控制（context window 較小的模型可調低）
MAX_CONTEXT_ARTICLES=2   # 最多注入幾篇文章（預設 2）
MAX_ARTICLE_CHARS=2000   # 每篇文章最多取幾個字元（預設 2000）
